# ============================================================
# HiveOps Environment Configuration Template
# Copy this file to `.env` and adjust values for your environment
# ============================================================

# ---------- Global Settings ----------
# Timezone for all services
TZ=Asia/Shanghai

# ---------- PostgreSQL Database ----------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=prometheus_db
POSTGRES_PORT=5432

# Full DATABASE_URL for backend (constructed from above if not set)
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://user:password@db:5432/prometheus_db

# ---------- JWT / Authentication ----------
# !! CHANGE THIS IN PRODUCTION !! Use a long random string (>= 32 chars)
JWT_SECRET=your-secret-key-change-in-production-please-2024
# Legacy alias (kept for backwards compatibility)
JWT_SECRET_KEY=your-secret-key-change-in-production-please-2024
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Prometheus Metrics ----------
# Set to "true" to expose /metrics endpoint on backend
ENABLE_METRICS=true

# ---------- MinIO Object Storage ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=beehive-attachments
# Set to "true" if using HTTPS
MINIO_SECURE=false

# MinIO console ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---------- Service Ports (Host Mappings) ----------
BACKEND_PORT=8000
BACKEND_DEBUG_PORT=5678
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090

# ---------- Logging ----------
# Valid values: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================
# Hive Alert Thresholds
# Can be configured individually OR via single JSON HIVE_ALERT_THRESHOLDS
# (Individual env vars take precedence if HIVE_ALERT_THRESHOLDS is not set)
# ============================================================

# Option A: Single JSON blob (overrides all individual env vars below)
# Example:
# HIVE_ALERT_THRESHOLDS={"high_temp":38.0,"low_temp":10.0,"weight_loss":5.0,"inspection_cycle_days":7,"sensor_offline_minutes":30,"sensor_rate_limit":60,"email_alert_enabled":true,"alert_severity_level":"WARNING"}
HIVE_ALERT_THRESHOLDS=

# Option B: Individual variables (used if HIVE_ALERT_THRESHOLDS is empty)
# 高温告警阈值（摄氏度）
HIVE_HIGH_TEMP_THRESHOLD=38.0
# 低温告警阈值（摄氏度）
HIVE_LOW_TEMP_THRESHOLD=10.0
# 失重告警阈值（千克/日）
HIVE_WEIGHT_LOSS_THRESHOLD=5.0
# 巡检周期（天）
HIVE_INSPECTION_CYCLE_DAYS=7
# 传感器掉线判定时长（分钟）
HIVE_SENSOR_OFFLINE_MINUTES=30
# 传感器数据限流阈值（次/分钟）
HIVE_SENSOR_RATE_LIMIT=60
# 邮件告警开关 (true/false)
HIVE_EMAIL_ALERT_ENABLED=true
# 告警严重程度阈值 (INFO/WARNING/CRITICAL)
HIVE_ALERT_SEVERITY_LEVEL=WARNING

# ---------- Frontend ----------
VITE_API_BASE_URL=http://localhost:8000
